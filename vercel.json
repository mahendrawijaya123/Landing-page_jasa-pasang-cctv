{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/_vercel/insights(.*)",
            "dest": "/_vercel/insights$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}